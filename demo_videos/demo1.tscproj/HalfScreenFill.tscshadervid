{
    "code":  "\nuniform vec4  _Color;\nuniform float _Position;\nuniform float _Speed;\nuniform float _Angle;\nuniform float _Frequency;\nuniform float _Amplitude;\n\nconst float PI = 3.14159265359;\n\nvec2 rotate( vec2 uv, vec2 imageSize, float rads ) {\n    rads -= 1.570796;\n    uv -= 0.5;\n    uv.x *= imageSize.x / imageSize.y;\n    uv = mat2( cos( rads ), sin( rads ), -sin( rads ), cos( rads ) ) * uv;\n    uv += 0.5;\n    return uv;\n}\n\nvec4 drawWave( vec2 st, vec4 inputColor, vec4 waveColor, float feather )\n{\n    float animationSpeedAmplitude = _Time * _Speed;\n    float animationSpeedShift = _Time * _Speed * 0.4;\n    \n    // Input _Position should correspond with the percentage of wave coverage in the X direction when _Frequency is 0 and the wave is drawn vertically\n    float coverage = 1.0 - ( ( _Position - 50.0 ) * ( _ImageSize.x / _ImageSize.y ) + 50.0 ) / 100.0;\n    \n    // Input _Frequency should correspond with the num of peaks present when wave is drawn vertically\n    float frequency = _Frequency * 6.25;\n    \n    // Input _Amplitude should correspond with the percentage of horizontal space covered by wave from peak to trough\n    float amplitude = _Amplitude / 50.0;\n    \n    float y = coverage + sin( 1.0 + animationSpeedAmplitude ) * sin( st.x * frequency - animationSpeedShift ) * amplitude * 0.5;\n    return mix( waveColor, inputColor, smoothstep( st.y, st.y + feather, y ) );\n}\n\nvec4 colorAtPoint( vec2 point, vec4 inputColor, vec4 waveColor, float feather )\n{\n    return drawWave( point, inputColor, waveColor, feather );\n}\n\nvoid main() {\n    _FragColor = vec4( 0.0 );\n    vec2 uv = rotate( _TexCoord, _ImageSize, _Angle );\n\n    const float feather = 0.005;\n    _FragColor = mix( _FragColor, colorAtPoint( uv, _FragColor, _Color, feather ), 1.0 );\n} \n  ",
